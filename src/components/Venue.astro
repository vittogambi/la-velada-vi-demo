---
---

<section class="py-16 px-6 section-glow" id="estadio">
  <div class="max-w-4xl mx-auto relative z-10">
    <h2 class="text-2xl sm:text-3xl text-[#c9a227] font-bold mb-2 text-center tracking-wider" style="font-family: 'Cinzel', serif;">EL ESTADIO</h2>
    <p class="text-[#c0c0c0] text-sm text-center mb-10">Estadio de La Cartuja · Sevilla, España</p>

    <div class="card-glass rounded-2xl overflow-hidden">
      <div class="aspect-[21/9] min-h-[220px] relative overflow-hidden bg-[#0d1324]">
        <iframe
          class="absolute inset-0 w-full h-full border-0 opacity-90 hover:opacity-100 transition-opacity duration-300 grayscale hover:grayscale-0"
          src="https://www.openstreetmap.org/export/embed.html?bbox=-6.02%2C37.405%2C-5.99%2C37.43&layer=mapnik&marker=37.417278%2C-6.005304"
          loading="eager"
          title="Ubicación del Estadio de La Cartuja"
        ></iframe>
      </div>
      <a
        href="https://www.google.com/maps/search/Estadio+Ol%C3%ADmpico+de+la+Cartuja+Sevilla"
        target="_blank"
        rel="noopener noreferrer"
        class="block py-3 px-4 text-center text-sm text-[#c9a227] hover:text-[#e5c04a] transition-colors border-b border-[#1e2a4a]"
      >
        Abrir en Google Maps
      </a>
      <div class="p-6 sm:p-8">
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
          <div class="text-center sm:text-left">
            <p class="text-xs text-[#c9a227] uppercase tracking-wider mb-1 font-semibold">Capacidad</p>
            <p class="text-white text-lg font-bold" style="font-family: 'Inter', system-ui, sans-serif;">80.000 personas</p>
            <p class="text-[#c0c0c0] text-xs mt-1">El mayor aforo de La Velada hasta la fecha</p>
          </div>
          <div class="text-center">
            <p class="text-xs text-[#c9a227] uppercase tracking-wider mb-1 font-semibold">Ubicación</p>
            <p class="text-white text-lg font-bold" style="font-family: 'Inter', system-ui, sans-serif;">Isla de la Cartuja</p>
            <p class="text-[#c0c0c0] text-xs mt-1">Sevilla, Andalucía</p>
          </div>
          <div class="text-center sm:text-right">
            <p class="text-xs text-[#c9a227] uppercase tracking-wider mb-1 font-semibold">Horario</p>
            <p class="text-white text-lg font-bold" style="font-family: 'Inter', system-ui, sans-serif;">20:00h CET</p>
            <p class="text-[#c0c0c0] text-xs mt-1">Hasta las 2-3h de la madrugada</p>
          </div>
        </div>
        <div class="mt-6 pt-6 border-t border-[#1e2a4a]">
          <p class="text-[#c0c0c0] text-sm leading-relaxed text-center">
            La Cartuja fue elegida por ser el único estadio de España con capacidad para 80.000 personas
            que permite terminar el evento de madrugada, mejorando la experiencia para audiencias internacionales
            en Latinoamérica.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
