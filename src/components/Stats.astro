---
const stats = [
  { value: '10', label: 'Combates', icon: '🥊' },
  { value: '22', label: 'Participantes', icon: '👤' },
  { value: '7', label: 'Países', icon: '🌎' },
  { value: '80K', label: 'Aforo', icon: '🏟️' },
];
---

<section class="py-12 px-6">
  <div class="max-w-4xl mx-auto">
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 sm:gap-6">
      {stats.map((s) => (
        <div class="card-glass rounded-xl p-6 text-center group hover:scale-[1.02] transition-transform duration-200">
          <p class="text-3xl sm:text-4xl font-bold text-white mb-1" style="font-family: 'Inter', system-ui, sans-serif;">
            {s.value}
          </p>
          <p class="text-xs sm:text-sm text-[#c9a227] uppercase tracking-wider font-medium">{s.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>
