---

<section class="py-16 px-6 section-glow" id="combates">
  <div class="max-w-3xl mx-auto relative z-10">
    <h2 class="text-2xl sm:text-3xl text-[#c9a227] font-bold mb-2 text-center tracking-wider" style="font-family: 'Cinzel', serif;">COMBATES</h2>
    <p class="text-[#c0c0c0] text-sm text-center mb-12">La Velada del Año VI · 10 peleas en la Cartuja</p>
    
    <div class="space-y-5">
      {combates.map((c, idx) => (
        <article
          class="combate-card group rounded-xl overflow-hidden transition-all duration-300 opacity-0 translate-y-6"
          class:list={[
            c.mainEvent ? 'card-main-event' : 'card-glass',
          ]}
          data-combate={c.id}
          data-open="false"
        >
          <div class="flex flex-wrap items-center gap-2 px-4 pt-3 pb-1">
            <span class="text-xs font-semibold text-[#c9a227]/80 uppercase tracking-wider">Combate {idx + 1}</span>
            {c.tags.map((tag) => (
              <span class="text-[10px] px-2 py-0.5 rounded-full bg-[#1e2a4a] text-[#c0c0c0] border border-[#2a3a5a]">
                {tag}
              </span>
            ))}
          </div>
          <button
            type="button"
            class="w-full py-4 px-6 flex items-center justify-between gap-4 sm:gap-6"
            aria-expanded="false"
            aria-controls={`desc-${c.id}`}
            data-toggle
          >
            <div class="flex-1 min-w-0 text-left">
              <span class="text-base sm:text-lg font-bold text-white block truncate" style="font-family: 'Cinzel', serif;"><span class="mr-1.5">{c.pais1}</span>{c.luchador1}</span>
            </div>
            <div class:list={[
              "shrink-0 flex items-center justify-center w-12 h-12 sm:w-14 sm:h-14 rounded-full border-2 border-[#c9a227]",
              c.mainEvent ? 'bg-[#c9a227]/10 shadow-[0_0_20px_rgba(201,162,39,0.2)]' : 'bg-[#0f1629]'
            ]}>
              <span class="text-sm sm:text-base font-black text-[#c9a227]" style="font-family: 'Inter', system-ui, sans-serif;">VS</span>
            </div>
            <div class="flex-1 min-w-0 text-right">
              <span class="text-base sm:text-lg font-bold text-white block truncate" style="font-family: 'Cinzel', serif;">{c.luchador2}<span class="ml-1.5">{c.pais2}</span></span>
            </div>
            <svg class="w-5 h-5 text-[#c9a227] shrink-0 transition-transform duration-300 group-data-[open]:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div
            id={`desc-${c.id}`}
            class="grid grid-rows-[0fr] transition-[grid-template-rows] duration-300 ease-out data-[open]:grid-rows-[1fr]"
            data-content
          >
            <div class="overflow-hidden">
              <div class="border-t border-[#1e2a4a] p-6 pt-4">
                <p class="text-[#c0c0c0] text-sm leading-relaxed">{c.descripcion}</p>
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('[data-toggle]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const article = btn.closest('article');
      const content = article?.querySelector('[data-content]');
      const isOpen = article?.getAttribute('data-open') === 'true';

      document.querySelectorAll('[data-content]').forEach((el) => {
        el.removeAttribute('data-open');
      });
      document.querySelectorAll('article[data-combate]').forEach((a) => {
        a.setAttribute('data-open', 'false');
      });

      if (!isOpen && content && article) {
        content.setAttribute('data-open', '');
        article.setAttribute('data-open', 'true');
      }
    });
  });

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry, i) => {
        if (entry.isIntersecting) {
          const el = entry.target;
          el.style.animationDelay = `${i * 0.05}s`;
          el.classList.add('animate-fade-in-up');
          el.classList.remove('opacity-0', 'translate-y-6');
          el.style.opacity = '1';
          el.style.transform = 'translateY(0)';
        }
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -30px 0px' }
  );
  document.querySelectorAll('.combate-card').forEach((card) => observer.observe(card));
</script>
