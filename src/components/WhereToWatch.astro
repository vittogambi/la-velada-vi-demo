---
---

<section class="py-16 px-6 section-glow" id="donde-ver">
  <div class="max-w-3xl mx-auto relative z-10">
    <h2 class="text-2xl sm:text-3xl text-[#c9a227] font-bold mb-2 text-center tracking-wider" style="font-family: 'Cinzel', serif;">DÓNDE VER</h2>
    <p class="text-[#c0c0c0] text-sm text-center mb-10">Streaming gratuito en directo</p>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      <a
        href="https://twitch.tv/ibai"
        target="_blank"
        rel="noopener"
        class="card-glass rounded-xl p-6 flex items-center gap-5 group hover:scale-[1.02] transition-transform duration-200"
      >
        <div class="shrink-0 w-14 h-14 rounded-xl bg-[#9146ff]/10 border border-[#9146ff]/30 flex items-center justify-center group-hover:bg-[#9146ff]/20 transition-colors">
          <svg class="w-7 h-7 text-[#9146ff]" viewBox="0 0 24 24" fill="currentColor"><path d="M11.571 4.714h1.715v5.143H11.57zm4.715 0H18v5.143h-1.714zM6 0L1.714 4.286v15.428h5.143V24l4.286-4.286h3.428L22.286 12V0zm14.571 11.143l-3.428 3.428h-3.429l-3 3v-3H6.857V1.714h13.714Z"/></svg>
        </div>
        <div>
          <p class="text-white font-bold text-lg">Twitch</p>
          <p class="text-[#c0c0c0] text-sm">twitch.tv/ibai</p>
          <p class="text-[#9146ff] text-xs mt-1 font-medium">Gratis · Sin suscripción</p>
        </div>
      </a>

      <a
        href="https://youtube.com/@ibaillanos"
        target="_blank"
        rel="noopener"
        class="card-glass rounded-xl p-6 flex items-center gap-5 group hover:scale-[1.02] transition-transform duration-200"
      >
        <div class="shrink-0 w-14 h-14 rounded-xl bg-[#ff0000]/10 border border-[#ff0000]/30 flex items-center justify-center group-hover:bg-[#ff0000]/20 transition-colors">
          <svg class="w-7 h-7 text-[#ff0000]" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
        </div>
        <div>
          <p class="text-white font-bold text-lg">YouTube</p>
          <p class="text-[#c0c0c0] text-sm">@ibaillanos</p>
          <p class="text-[#ff0000] text-xs mt-1 font-medium">Gratis · En directo</p>
        </div>
      </a>
    </div>

    <div class="mt-8 card-glass rounded-xl p-5 text-center">
      <p class="text-xs text-[#c0c0c0] mb-1">Horario por zonas</p>
      <div class="flex flex-wrap justify-center gap-4 sm:gap-6 mt-3" style="font-family: 'Inter', system-ui, sans-serif;">
        <div>
          <p class="text-white text-sm font-bold">20:00h</p>
          <p class="text-[#c9a227] text-[10px] uppercase tracking-wider">España</p>
        </div>
        <div class="w-px h-8 bg-[#1e2a4a]"></div>
        <div>
          <p class="text-white text-sm font-bold">13:00h</p>
          <p class="text-[#c9a227] text-[10px] uppercase tracking-wider">Colombia / MX</p>
        </div>
        <div class="w-px h-8 bg-[#1e2a4a]"></div>
        <div>
          <p class="text-white text-sm font-bold">15:00h</p>
          <p class="text-[#c9a227] text-[10px] uppercase tracking-wider">Argentina</p>
        </div>
        <div class="w-px h-8 bg-[#1e2a4a]"></div>
        <div>
          <p class="text-white text-sm font-bold">14:00h</p>
          <p class="text-[#c9a227] text-[10px] uppercase tracking-wider">Venezuela</p>
        </div>
      </div>
    </div>
  </div>
</section>
